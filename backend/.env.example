# ──────────────────────────────────────────────────────────
# backend/.env.example
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# ──────────────────────────────────────────────────────────

# ─── Application ──────────────────────────────────────────
APP_NAME=Helpdesk Ticket Management System
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ─── Database (PostgreSQL) ────────────────────────────────
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/helpdesk_db
DB_ECHO=false

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Future: AI / RAG Integration (Phase 2) ──────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
VECTOR_DB_URL=your-vector-db-connection-string-here
EMBEDDING_MODEL=text-embedding-ada-002
